# ─── Server ───────────────────────────────────────────────
PORT=4000

# ─── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ai_mentor

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── ElevenLabs ───────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # default: Bella

# ─── Whisper (uses OpenAI key above) ──────────────────────
# No extra key needed – Whisper is part of the OpenAI SDK

# ─── Replicate (Stable Diffusion via SDXL) ────────────────
REPLICATE_API_TOKEN=r8_...

# ─── Pinecone ─────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX=ai-mentor-memory

# ─── Frontend URL (for CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:3000
